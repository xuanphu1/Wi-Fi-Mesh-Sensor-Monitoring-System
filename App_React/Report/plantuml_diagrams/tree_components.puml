@startmindmap
<style>
mindmapDiagram {
  node {
    Padding 10
    Margin 15
    RoundCorner 10
    BackgroundColor white
    FontName sans-serif
  }
  .folder {
    BorderColor #4285F4
    BorderThickness 2
  }
  .file {
    BorderColor #34A853
    BorderThickness 2
  }
  .title {
    BackgroundColor #041029
    BorderColor #041029
    FontColor white
  }
  arrow {
    LineColor #888888
    LineThickness 2
  }
}
</style>
+ <&folder> Folder Tree - components <<title>>
++ <color:#4285F4><&folder></color> components <<folder>>
+++ <color:#34A853><&file></color> FirmwareCard.tsx <<file>>
+++ <color:#34A853><&file></color> GlassCard.tsx <<file>>
+++ <color:#34A853><&file></color> GlobalToast.tsx <<file>>
+++ <color:#34A853><&file></color> MetricTile.tsx <<file>>
+++ <color:#34A853><&file></color> MiniLineChart.tsx <<file>>
+++ <color:#34A853><&file></color> MiniMetricCard.tsx <<file>>
+++ <color:#34A853><&file></color> NodeCard.tsx <<file>>
+++ <color:#34A853><&file></color> QuickActionButton.tsx <<file>>
+++ <color:#34A853><&file></color> SelectorCard.tsx <<file>>
+++ <color:#34A853><&file></color> SensorCard.tsx <<file>>
+++ <color:#34A853><&file></color> SettingMenuCard.tsx <<file>>
+++ <color:#34A853><&file></color> SystemChart.tsx <<file>>
