# =============================================================
#   Wi-Fi Mesh Sensor Monitoring System — Root .gitignore
# =============================================================

# ─────────────────────────────────────────
#  ESP-IDF / ESP-MDF (MSMS_Project, MeshGateWay, Node_MSMS)
# ─────────────────────────────────────────

# Build output (generated by idf.py build)
build/

# ESP-IDF SDK configuration (generated, can be large & machine-specific)
sdkconfig
sdkconfig.old
sdkconfig.defaults.esp32*

# IDF Component Manager lock file (regenerated automatically)
dependencies.lock

# Managed components fetched by idf component manager
managed_components/

# Local IDE / editor caches for ESP-IDF
.cache/
.vs/
.vscode/ipch/

# LaTeX / texput log sometimes generated by doc tools
texput.log

# Error log dumps
Error.txt

# ─────────────────────────────────────────
#  React Native / Expo (App_React)
# ─────────────────────────────────────────

# Node dependencies
node_modules/

# Expo local config & cache
.expo/
.expo-shared/

# Native build outputs
android/
ios/

# Expo dist / web build
dist/
web-build/

# ─────────────────────────────────────────
#  React Dashboard (DashboardManagerWifiMesh)
# ─────────────────────────────────────────

# Create-React-App / Craco production build
# (keep source, ignore compiled output)
DashboardManagerWifiMesh/build/

# Websocket server node_modules
DashboardManagerWifiMesh/websocket-server/node_modules/

# TLS/SSL certificates (sensitive)
DashboardManagerWifiMesh/websocket-server/certs/

# ─────────────────────────────────────────
#  Python (Server_Pi_3, PythonStressTest)
# ─────────────────────────────────────────

# Byte-compiled / optimized Python files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
*.egg-info/
dist/
build/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# SQLite databases (can be large & contain runtime data)
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────
#  Environment & Secrets
# ─────────────────────────────────────────

.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.crt
*.cert
secrets.*

# ─────────────────────────────────────────
#  OS & Editor generated files
# ─────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Windows
desktop.ini
$RECYCLE.BIN/

# VSCode workspace settings (keep .vscode/launch.json, tasks.json if desired)
.vscode/settings.json
.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml

# ─────────────────────────────────────────
#  Logs & Debug
# ─────────────────────────────────────────

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt
pip-delete-this-directory.txt

# ─────────────────────────────────────────
#  Package manager lock files
#  (lock files are useful to commit inside sub-projects,
#   but listed here to allow selective un-ignoring if needed)
# ─────────────────────────────────────────

# Uncomment the lines below ONLY if you do NOT want to track lock files:
# package-lock.json
# yarn.lock

# ─────────────────────────────────────────
#  Reports & generated documents
# ─────────────────────────────────────────

# Uncomment if the Report/ folders contain generated PDFs / compiled docs:
# Report/
# *.pdf
