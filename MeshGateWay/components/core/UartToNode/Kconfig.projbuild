menu "UART to Node"

    config UART_TO_NODE_ENABLE
        bool "Enable UART-to-node task"
        default y

    config UART_TO_NODE_UART_NUM
        int "UART port number (0/1/2)"
        range 0 2
        default 1

    config UART_TO_NODE_BAUDRATE
        int "UART baudrate"
        range 1200 2000000
        default 115200

    config UART_TO_NODE_TX_PIN
        int "TX GPIO"
        range -1 39
        default 17

    config UART_TO_NODE_RX_PIN
        int "RX GPIO"
        range -1 39
        default 16

    config UART_TO_NODE_RTS_PIN
        int "RTS GPIO (-1 = disable)"
        range -1 39
        default -1

    config UART_TO_NODE_CTS_PIN
        int "CTS GPIO (-1 = disable)"
        range -1 39
        default -1

    config UART_TO_NODE_SEND_PERIOD_MS
        int "Send period (ms)"
        range 50 5000
        default 500

    config UART_TO_NODE_RX_IDLE_RESET_MS
        int "Idle timeout to reset handshake (ms)"
        range 200 10000
        default 2000

    config UART_TO_NODE_TASK_STACK
        int "Task stack (words)"
        range 2048 16384
        default 4096

    config UART_TO_NODE_TASK_PRIO
        int "Task priority"
        range 1 25
        default 5

endmenu

