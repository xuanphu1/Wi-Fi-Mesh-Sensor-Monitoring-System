# Gateway WiFi: SoftAP + STA (không dùng Mesh-Lite / IoT Bridge).
# NAT để client SoftAP đi Internet qua STA khi đã kết nối router.
CONFIG_LWIP_IP_FORWARD=y
CONFIG_LWIP_IPV4_NAPT=y

CONFIG_GATEWAY_ROUTER_SSID=""
CONFIG_GATEWAY_ROUTER_PASSWORD=""
CONFIG_GATEWAY_SOFTAP_SSID="ROOT_AP"
CONFIG_GATEWAY_SOFTAP_PASSWORD="12345678"
CONFIG_GATEWAY_SOFTAP_CHANNEL=11
CONFIG_GATEWAY_SOFTAP_MAX_STA=6
# CONFIG_GATEWAY_SOFTAP_SSID_MAC_SUFFIX is not set
CONFIG_GATEWAY_STATIC_DNS="114.114.114.114"
CONFIG_GATEWAY_STORAGE_MAX_PAYLOAD=384
CONFIG_GATEWAY_UDP_TASK_STACK=8192

# Timer in gateway (print_system_info).
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=8192

# DNS:53 + UDP + lwIP
CONFIG_LWIP_MAX_SOCKETS=16
