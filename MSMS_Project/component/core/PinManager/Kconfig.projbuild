menu "PinManager — UART"

    config PIN_UART_TX
        int "UART TX GPIO"
        default 16 if IDF_TARGET_ESP32
        default 5 if IDF_TARGET_ESP32C6
        default 3 if IDF_TARGET_ESP32C3
        help
            Chân TX (GPIO) của UART đã chọn (UART port bên dưới).

    config PIN_UART_RX
        int "UART RX GPIO"
        default 17 if IDF_TARGET_ESP32
        default 4 if IDF_TARGET_ESP32C6
        default 2 if IDF_TARGET_ESP32C3
        help
            Chân RX (GPIO).

    config PIN_UART_NUM
        int "UART port (UART_NUM_0=0, UART_NUM_1=1, UART_NUM_2=2)"
        range 0 2 if IDF_TARGET_ESP32
        range 0 1 if IDF_TARGET_ESP32C3
        range 0 1 if IDF_TARGET_ESP32C6
        default 2 if IDF_TARGET_ESP32
        default 1 if IDF_TARGET_ESP32C3
        default 1 if IDF_TARGET_ESP32C6
        help
            Bộ điều khiển UART: 0, 1 hoặc 2 (tùy chip có đủ UART).

    config UART_GATEWAY_BAUD_RATE
        int "UART gateway baudrate"
        default 2000000
        help
            Baudrate for the UART link from mesh root to gateway.

    config UART_PERIPHERAL_BAUD_RATE
        int "UART peripheral baudrate"
        default 9600
        help
            Baudrate for peripheral sensors over UART.

endmenu

menu "PinManager — I2C"

    config PIN_I2C_SDA
        int "I2C SDA GPIO"
        default 21 if IDF_TARGET_ESP32
        default 6 if IDF_TARGET_ESP32C6
        default 9 if IDF_TARGET_ESP32C3
        help
            SDA — dùng trong code qua macro PIN_I2C_SDA.

    config PIN_I2C_SCL
        int "I2C SCL GPIO"
        default 22 if IDF_TARGET_ESP32
        default 7 if IDF_TARGET_ESP32C6
        default 8 if IDF_TARGET_ESP32C3
        help
            SCL — PIN_I2C_SCL.

    config PIN_I2C_PORT
        int "I2C port (I2C_NUM_0=0, I2C_NUM_1=1)"
        range 0 1
        default 0
        help
            Port I2C phần cứng.

    config PIN_I2C_CLK_HZ
        int "I2C tốc độ (Hz)"
        default 400000
        help
            Clock bus I2C master.

    config I2CDEV_TIMEOUT
        int "I2C dev mutex / giao dịch timeout (ms)"
        default 1000
        help
            Timeout mutex và i2c_master_cmd_begin (ms).

    config I2CDEV_NOLOCK
        bool "Tắt mutex I2Cdev (không thread-safe)"
        default n
        help
            Bật: truy cập I2C không khóa mutex.

endmenu

menu "PinManager — SPI"

    config PIN_SPI_HOST
        int "SPI Host ID"
        default 3
        help
            ID của SPI Host (ví dụ: 1 = SPI2_HOST, 2 = SPI3_HOST).

    config PIN_SPI_MISO
        int "SPI MISO GPIO"
        default 4
        help
            Chân MISO cho SPI Peripheral.

    config PIN_SPI_MOSI
        int "SPI MOSI GPIO"
        default 13
        help
            Chân MOSI cho SPI Peripheral.

    config PIN_SPI_SCLK
        int "SPI SCLK GPIO"
        default 15
        help
            Chân SCLK cho SPI Peripheral.

    config PIN_SPI_CS
        int "SPI CS GPIO"
        default 5
        help
            Chân CS (Chip Select) cho SPI Peripheral.

endmenu

menu "PinManager — Pulse"

    config PIN_PULSE_1
        int "Pulse 1 GPIO"
        default 26
        help
            Chân cấu hình cho Pulse 1 Peripheral (ví dụ DHT11/22).

    config PIN_PULSE_2
        int "Pulse 2 GPIO"
        default 25
        help
            Chân cấu hình cho Pulse 2 Peripheral.

endmenu
